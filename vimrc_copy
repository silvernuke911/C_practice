set nocompatible
set number
set rnu
set termguicolors
" autocmd BufReadPost * startinsert
syntax on
colorscheme torte
filetype plugin indent on
" VS Code-ish colors
" Tell Vim that any word followed by ( is a Function
autocmd FileType c syntax match cFunction "\<\h\w*\>\s*(\@="
autocmd FileType c hi def link cFunction Function
hi Comment     guifg=#6A9955
hi Type        guifg=#569CD6
hi Function    guifg=#DCDCAA
hi Keyword     guifg=#C586C0 "C586C0 
hi Statement   guifg=#C586C0 "596cd6
hi String      guifg=#CE9178
hi Number      guifg=#B5CEA8
hi Constant    guifg=#B5CEA8
hi Identifier  guifg=#DCDCAA   " Many languages use this for function names
hi Special     guifg=#DCDCAA   " Some languages use this
hi Title       guifg=#DCDCAA   " Some languages use thise this for function names
hi Character   guifg=#FF7F7F " Red for characters (including single quotes)
hi SpecialChar guifg=#FF7F7F
hi PreProc     guifg=#C586C0
" Set relative line numbers to light gray
highlight LineNr guifg=#D3D3D3 guibg=NONE
highlight LineNr ctermfg=252
" "

call plug#begin('~/vimfiles/plugged')

Plug 'LunarWatcher/auto-pairs'

call plug#end()
set nowrap

set visualbell
set smartindent
set autoindent
set cindent


let g:AutoPairsMapCR = 1
set shiftwidth=4
set softtabstop=4
set tabstop=4

packadd comment
autocmd FileType c,cpp setlocal commentstring=//\ %s

" Enable system clipboard for all yank/delete/paste operations
set clipboard=unnamed

" Paste from system clipboard easily while in insert mode
inoremap <C-V> <C-R>*

" hi clear Italic
" hi clear Bold

" Active tab
hi TabLineSel guifg=#ffffff guibg=#cc0000 ctermfg=15 ctermbg=1

" Inactive tabs
hi TabLine guifg=#000000 guibg=#808080 ctermfg=0 ctermbg=8

" Empty tabline space
hi TabLineFill guifg=NONE guibg=#303030 ctermbg=0

" MAP F5 TO COMPILE AND EXECUTE
nnoremap <F5> :w<CR>:!gcc -Wall -Werror -Wextra -g "%:p" -o "%:p:r.exe" && "%:p:r.exe"<CR>
